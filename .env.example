# Frog AI v3.0 - Template Environment File
# Please copy this to .env and fill in your details.

# LLM Core Configuration
OPENAI_API_KEY=your_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_PROVIDER=openai
DEFAULT_MODEL=gpt-4o

# Memory Layer (Internal Network)
# Use 'frog-memory' when running via Docker Compose.
# Use 'localhost' if running the backend on host while database is in Docker.
CHROMA_HOST=frog-memory
CHROMA_PORT=8000

# Telegram Control (Optional)
# Get token from @BotFather
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
